<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{245397D4-4D37-4125-9399-681D24762800}</ProjectGuid>
        <MainSource>KittoXIDE.dpk</MainSource>
        <ProjectVersion>20.4</ProjectVersion>
        <FrameworkType>VCL</FrameworkType>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Release</Config>
        <Platform Condition="'$(Platform)'==''">Win32</Platform>
        <TargetedPlatforms>3</TargetedPlatforms>
        <AppType>Package</AppType>
        <ProjectName Condition="'$(ProjectName)'==''">KittoXIDE</ProjectName>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Base)'=='true') or '$(Base_Win32)'!=''">
        <Base_Win32>true</Base_Win32>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Base)'=='true') or '$(Base_Win64)'!=''">
        <Base_Win64>true</Base_Win64>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='WinARM64EC' and '$(Base)'=='true') or '$(Base_WinARM64EC)'!=''">
        <Base_WinARM64EC>true</Base_WinARM64EC>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <DCC_DcuOutput>..\..\..\Lib\D13\$(Platform)</DCC_DcuOutput>
        <DCC_ExeOutput>.\$(Platform)\$(Config)</DCC_ExeOutput>
        <DCC_E>false</DCC_E>
        <DCC_N>false</DCC_N>
        <DCC_S>false</DCC_S>
        <DCC_F>false</DCC_F>
        <DCC_K>false</DCC_K>
        <GenDll>true</GenDll>
        <GenPackage>true</GenPackage>
        <VerInfo_Locale>1033</VerInfo_Locale>
        <VerInfo_Keys>CompanyName=Ethea S.r.l.;FileDescription=KittoX IDE Tools Package;FileVersion=4.0.10.0;InternalName=KittoXIDE;LegalCopyright=Copyright (c) Ethea S.r.l.;LegalTrademarks=;OriginalFilename=;ProductName=KittoXIDE;ProductVersion=4.0;Comments=</VerInfo_Keys>
        <DCC_Description>KittoX IDE Tools Package</DCC_Description>
        <DCC_OutputNeverBuildDcps>true</DCC_OutputNeverBuildDcps>
        <DesignOnlyPackage>true</DesignOnlyPackage>
        <DllSuffix>$(Auto)</DllSuffix>
        <DCC_DUPLICATE_CTOR_DTOR>false</DCC_DUPLICATE_CTOR_DTOR>
        <SanitizedProjectName>KittoXIDE</SanitizedProjectName>
        <DCC_SYMBOL_PLATFORM>false</DCC_SYMBOL_PLATFORM>
        <DCC_UNIT_PLATFORM>false</DCC_UNIT_PLATFORM>
        <DCC_UsePackage>VclSmp;KittoXCore;$(DCC_UsePackage)</DCC_UsePackage>
        <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
        <VerInfo_MajorVer>4</VerInfo_MajorVer>
        <VerInfo_Release>10</VerInfo_Release>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base_Win32)'!=''">
        <DCC_UsePackage>rtl;$(DCC_UsePackage)</DCC_UsePackage>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base_Win64)'!=''">
        <DCC_UsePackage>rtl;$(DCC_UsePackage)</DCC_UsePackage>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base_WinARM64EC)'!=''">
        <DCC_Namespace>Winapi;System.Win;Data.Win;Datasnap.Win;Web.Win;Soap.Win;Xml.Win;$(DCC_Namespace)</DCC_Namespace>
        <BT_BuildType>Debug</BT_BuildType>
        <VerInfo_Keys>CompanyName=;FileDescription=$(MSBuildProjectName);FileVersion=4.0.10.0;InternalName=;LegalCopyright=;LegalTrademarks=;OriginalFilename=;ProgramID=com.embarcadero.$(MSBuildProjectName);ProductName=$(MSBuildProjectName);ProductVersion=1.0.0.0;Comments=</VerInfo_Keys>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
        <DCC_DebugDCUs>true</DCC_DebugDCUs>
        <DCC_Optimize>false</DCC_Optimize>
        <DCC_GenerateStackFrames>true</DCC_GenerateStackFrames>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2)'!=''">
        <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
        <DCC_Define>RELEASE;$(DCC_Define)</DCC_Define>
        <DCC_SymbolReferenceInfo>0</DCC_SymbolReferenceInfo>
        <DCC_DebugInformation>0</DCC_DebugInformation>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="rtl.dcp"/>
        <DCCReference Include="designide.dcp"/>
        <DCCReference Include="VclSmp.dcp"/>
        <DCCReference Include="KittoXCore.dcp"/>
        <DCCReference Include="..\..\Source\KIDE.IOTA.ProjectWizard.pas"/>
        <DCCReference Include="..\..\Source\KIDE.IOTA.Register.pas"/>
        <DCCReference Include="..\..\Source\KIDE.IOTA.ProjectCreator.pas"/>
        <DCCReference Include="..\..\Source\KIDE.IOTA.Utils.pas"/>
        <DCCReference Include="..\..\Source\KIDE.IOTA.ModuleCreator.pas"/>
        <DCCReference Include="..\..\Source\KIDE.IOTA.MainFormCreator.pas"/>
        <DCCReference Include="..\..\Source\KIDE.YAMLHighlighter.pas"/>
        <DCCReference Include="..\..\Source\KIDE.Controls.pas">
            <Form>BaseFrame</Form>
            <DesignClass>TFrame</DesignClass>
        </DCCReference>
        <DCCReference Include="..\..\Source\KIDE.BaseFrameUnit.pas">
            <Form>BaseFrame</Form>
            <DesignClass>TFrame</DesignClass>
        </DCCReference>
        <DCCReference Include="..\..\Source\KIDE.ProjectTemplateFrameUnit.pas">
            <Form>ProjectTemplateFrame</Form>
            <DesignClass>TFrame</DesignClass>
        </DCCReference>
        <DCCReference Include="..\..\Source\KIDE.ProjectTemplate.pas"/>
        <DCCReference Include="..\..\Source\KIDE.BaseFormUnit.pas">
            <Form>BaseForm</Form>
        </DCCReference>
        <DCCReference Include="..\..\Source\KIDE.BaseWizardFormUnit.pas">
            <Form>BaseWizardForm</Form>
        </DCCReference>
        <DCCReference Include="..\..\Source\KIDE.NewProjectWizardFormUnit.pas">
            <Form>NewProjectWizardForm</Form>
        </DCCReference>
        <DCCReference Include="..\..\Source\KIDE.MRUOptions.pas"/>
        <DCCReference Include="..\..\Source\KIDE.Config.pas"/>
        <DCCReference Include="..\..\Source\KIDE.Project.pas"/>
        <DCCReference Include="..\..\Source\KIDE.MainDataModuleUnit.pas">
            <Form>MainDataModule</Form>
            <DesignClass>TDataModule</DesignClass>
        </DCCReference>
        <RcItem Include="..\..\Images\KittoVclApplication.ico">
            <ResourceType>ICON</ResourceType>
            <ResourceId>Icon_1</ResourceId>
        </RcItem>
        <RcItem Include="..\..\Images\KittoWindowsServiceApplication.ico">
            <ResourceType>ICON</ResourceType>
            <ResourceId>Icon_2</ResourceId>
        </RcItem>
        <RcItem Include="..\..\..\Kide\Bin\Config.yaml">
            <ResourceId>CONFIG_YAML</ResourceId>
            <ResourceType>RCDATA</ResourceType>
        </RcItem>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Release">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>Package</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality>
                <Excluded_Packages/>
                <Source>
                    <Source Name="MainSource">KittoXIDE.dpk</Source>
                </Source>
            </Delphi.Personality>
            <Platforms>
                <Platform value="Win32">True</Platform>
                <Platform value="Win64">True</Platform>
                <Platform value="Win64x">False</Platform>
                <Platform value="WinARM64EC">False</Platform>
            </Platforms>
            <Deployment Version="5"/>
        </BorlandProject>
        <ProjectFileVersion>12</ProjectFileVersion>
    </ProjectExtensions>
    <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')"/>
</Project>
