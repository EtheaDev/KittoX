<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{6653E83A-FED5-4454-9363-AF157EE90CAE}</ProjectGuid>
        <ProjectVersion>19.2</ProjectVersion>
        <FrameworkType>VCL</FrameworkType>
        <MainSource>KEmployeeDesktop.dpr</MainSource>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Release</Config>
        <Platform Condition="'$(Platform)'==''">Win64</Platform>
        <TargetedPlatforms>3</TargetedPlatforms>
        <AppType>Application</AppType>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <DCC_SYMBOL_PLATFORM>false</DCC_SYMBOL_PLATFORM>
        <SanitizedProjectName>KEmployeeDesktop</SanitizedProjectName>
        <DCC_DUPLICATE_CTOR_DTOR>false</DCC_DUPLICATE_CTOR_DTOR>
        <Manifest_File>$(BDS)\bin\default_app.manifest</Manifest_File>
        <VerInfo_Locale>1033</VerInfo_Locale>
        <VerInfo_Keys>CompanyName=Ethea S.r.l.;FileDescription=KEmployee Desktop;FileVersion=4.0.10.0;InternalName=KEmployeeDesktop;LegalCopyright=Copyright Ethea S.r.l.;LegalTrademarks=;OriginalFilename=;ProductName=KEmployee Desktop;ProductVersion=4.0;Comments=</VerInfo_Keys>
        <DCC_ExeOutput>..\Home</DCC_ExeOutput>
        <DCC_DcuOutput>..\Lib\$(Platform)</DCC_DcuOutput>
        <DCC_UnitSearchPath>..\..\..\Source;..\..\..\Source\EF;..\..\..\Source\ThirdParty;..\..\..\Source\ThirdParty\delphi-jose-jwt\Source;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
        <DCC_E>false</DCC_E>
        <DCC_N>false</DCC_N>
        <DCC_S>false</DCC_S>
        <DCC_F>false</DCC_F>
        <DCC_K>false</DCC_K>
        <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
        <DCC_Define>IBFB_SUPPORT;$(DCC_Define)</DCC_Define>
        <VerInfo_MajorVer>4</VerInfo_MajorVer>
        <VerInfo_Release>10</VerInfo_Release>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
        <DCC_Define>RELEASE;$(DCC_Define)</DCC_Define>
        <DCC_SymbolReferenceInfo>0</DCC_SymbolReferenceInfo>
        <DCC_DebugInformation>0</DCC_DebugInformation>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2)'!=''">
        <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
        <DCC_DebugDCUs>true</DCC_DebugDCUs>
        <DCC_Optimize>false</DCC_Optimize>
        <DCC_GenerateStackFrames>true</DCC_GenerateStackFrames>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="..\Source\UseKitto.pas"/>
        <DCCReference Include="..\Source\Rules.pas"/>
        <None Include="..\Home\Metadata\Config.yaml"/>
        <None Include="..\Home\Metadata\Views\Home.yaml"/>
        <None Include="..\Home\Metadata\Views\MainMenu.yaml"/>
        <None Include="..\Home\Metadata\Views\Countries.yaml"/>
        <None Include="..\Home\Metadata\Views\Customers.yaml"/>
        <None Include="..\Home\Metadata\Views\Departments.yaml"/>
        <None Include="..\Home\Metadata\Views\Employees.yaml"/>
        <None Include="..\Home\Metadata\Views\EmployeeProjects.yaml"/>
        <None Include="..\Home\Metadata\Views\Jobs.yaml"/>
        <None Include="..\Home\Metadata\Views\ProjDeptBudgets.yaml"/>
        <None Include="..\Home\Metadata\Views\Projects.yaml"/>
        <None Include="..\Home\Metadata\Views\SalaryHistories.yaml"/>
        <None Include="..\Home\Metadata\Views\Sales.yaml"/>
        <None Include="..\Home\Metadata\Views\Users.yaml"/>
        <None Include="..\Home\Metadata\Models\Country.yaml"/>
        <None Include="..\Home\Metadata\Models\Customer.yaml"/>
        <None Include="..\Home\Metadata\Models\Department.yaml"/>
        <None Include="..\Home\Metadata\Models\Employee.yaml"/>
        <None Include="..\Home\Metadata\Models\EmployeeProject.yaml"/>
        <None Include="..\Home\Metadata\Models\Job.yaml"/>
        <None Include="..\Home\Metadata\Models\ProjDeptBudget.yaml"/>
        <None Include="..\Home\Metadata\Models\Project.yaml"/>
        <None Include="..\Home\Metadata\Models\SalaryHistory.yaml"/>
        <None Include="..\Home\Metadata\Models\Sales.yaml"/>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Release">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>VCLApplication</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality>
                <Source>
                    <Source Name="MainSource">KEmployeeDesktop.dpr</Source>
                </Source>
                <Excluded_Packages/>
            </Delphi.Personality>
            <Platforms>
                <Platform value="Win32">True</Platform>
                <Platform value="Win64">True</Platform>
            </Platforms>
        </BorlandProject>
        <ProjectFileVersion>12</ProjectFileVersion>
    </ProjectExtensions>
    <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')"/>
</Project>
